---
import "../styles/global.css";
import { conversionReports, displayTitle, kindLabel, regulations, searchText } from "../lib/regulations";

const [primaryRegulation] = regulations;
const [conversion] = conversionReports;
const electricityRegulation = regulations.find((item) => item.metadata.slug === "pp-nomor-14-tahun-2012") ?? primaryRegulation;
const standardizationRegulation = regulations.find((item) => item.metadata.slug === "pp-nomor-34-tahun-2018") ?? conversion;
const licensingRegulation = regulations.find((item) => item.metadata.slug === "pp-nomor-28-tahun-2025") ?? primaryRegulation;
const environmentRegulation = regulations.find((item) => item.metadata.slug === "pp-nomor-22-tahun-2021") ?? primaryRegulation;
const safetyRegulation = regulations.find((item) => item.metadata.slug === "permen-esdm-nomor-10-tahun-2021") ?? electricityRegulation;
const businessRegulation = regulations.find((item) => item.metadata.slug === "permen-esdm-nomor-11-tahun-2021") ?? electricityRegulation;
const busbarRegulation = regulations.find((item) => item.metadata.slug === "permenperin-nomor-54-tahun-2024") ?? standardizationRegulation;
const title = "Website Peraturan Energi";
const typeSearchAliases: Record<string, string> = {
  UU: "Undang-Undang",
  PP: "Peraturan Pemerintah",
  PERPRES: "Peraturan Presiden",
  "PERMEN ESDM": "Peraturan Menteri ESDM",
  "PERMEN LHK": "Peraturan Menteri LHK",
  PERMENPERIN: "Peraturan Menteri Perindustrian",
  PERMEN: "Peraturan Menteri"
};
const searchRows = regulations.flatMap((item) => {
  const title = displayTitle(item);
  const documentTypeAlias = typeSearchAliases[item.metadata.document_type] ?? item.metadata.document_type;
  const expandedTitle = title.startsWith(item.metadata.document_type)
    ? `${documentTypeAlias}${title.slice(item.metadata.document_type.length)}`
    : title;
  return item.paragraphs.map((paragraph) => ({
    slug: item.metadata.slug,
    title,
    searchTitle: `${title} ${expandedTitle} ${documentTypeAlias}`,
    documentType: item.metadata.document_type,
    documentTypeAlias,
    number: item.metadata.number,
    year: item.metadata.year,
    id: paragraph.id,
    kind: paragraph.kind,
    label: kindLabel(paragraph.kind),
    part: paragraph.part,
    text: paragraph.text
  }));
});
const totalWords = regulations.reduce((sum, item) => sum + searchText(item).split(/\s+/).filter(Boolean).length, 0);
const totalBodyArticles = regulations.reduce((sum, item) => sum + item.quality.body_article_count, 0);
const totalParagraphs = regulations.reduce((sum, item) => sum + item.quality.paragraph_count, 0);
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Prototipe website full-text peraturan energi Indonesia." />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <strong>Website Peraturan</strong>
        <span>Energi Indonesia</span>
      </a>
      <nav class="nav-links" aria-label="Navigasi utama">
        <a href="#pencarian">Pencarian</a>
        <a href="#koleksi">Koleksi</a>
        <a href="/prototype/reverse-prompt/">QA Pipeline</a>
      </nav>
    </header>

    <main>
      <section class="home-hero" aria-labelledby="page-title">
        <div class="home-hero-inner">
          <p class="eyebrow">Arsip Digital Peraturan Energi</p>
          <h1 id="page-title">Website Peraturan Energi Indonesia</h1>
          <p class="home-lede">
            Pencarian full-text ke dalam judul, pasal, batang tubuh, dan penjelasan peraturan
            energi. Dibangun sebagai arsip digital yang cepat dibaca dan mudah ditelusuri.
          </p>

          <section id="pencarian" class="home-search" aria-label="Pencarian peraturan">
            <form class="search-form" id="site-search-form">
              <label class="sr-only" for="site-search">Cari peraturan</label>
              <input
                id="site-search"
                type="search"
                autocomplete="off"
                placeholder="Cari contoh: tarif listrik"
              />
              <button type="submit">Cari</button>
            </form>
            <div id="search-summary" class="search-summary" aria-live="polite"></div>
            <div id="search-results" class="search-results is-hidden"></div>
          </section>
        </div>

        <div class="home-preview-strip" aria-label="Cuplikan konten website">
          <a class="preview-card" href={`/peraturan/${primaryRegulation.metadata.slug}/`}>
            <span>Dokumen utama</span>
            <strong>{primaryRegulation.metadata.document_type} {primaryRegulation.metadata.number}/{primaryRegulation.metadata.year}</strong>
            <em>{displayTitle(primaryRegulation)}</em>
          </a>
          <a class="preview-card preview-card-tall" href={`/peraturan/${conversion.metadata.slug}/`}>
            <span>Hasil reverse prompt</span>
            <strong>UU 20/2014</strong>
            <em>{conversion.quality.paragraph_count} paragraf siap dibaca sebagai konten utama.</em>
          </a>
          <a class="preview-card" href="#pencarian">
            <span>Pencarian isi</span>
            <strong>{totalWords.toLocaleString("id-ID")} kata</strong>
            <em>Terindeks sampai batang tubuh dan penjelasan.</em>
          </a>
        </div>
      </section>

      <section class="home-stats" aria-label="Statistik koleksi">
        <div>
          <strong>{regulations.length}</strong>
          <span>Total Peraturan</span>
        </div>
        <div>
          <strong>{totalParagraphs.toLocaleString("id-ID")}</strong>
          <span>Paragraf Terstruktur</span>
        </div>
        <div>
          <strong>{totalBodyArticles}</strong>
          <span>Pasal Batang Tubuh</span>
        </div>
        <div>
          <strong>{totalWords.toLocaleString("id-ID")}</strong>
          <span>Kata Terindeks</span>
        </div>
      </section>

      <section id="koleksi" class="home-content" aria-labelledby="collection-title">
        <div class="home-section">
          <p class="eyebrow">Koleksi Utama</p>
          <h2 id="collection-title">Peraturan yang Bisa Dibaca Penuh</h2>
          <div class="document-list">
            {
              regulations.map((item) => (
                <a class="popular-link" href={`/peraturan/${item.metadata.slug}/`}>
                  <span>{item.metadata.document_type} Tahun {item.metadata.year}</span>
                  <strong>{item.metadata.document_type} {item.metadata.number}/{item.metadata.year}</strong>
                  <em>{displayTitle(item)}</em>
                </a>
              ))
            }
          </div>
        </div>

        <div class="home-section">
          <p class="eyebrow">Kategori Peraturan</p>
          <h2>Jalur Cepat</h2>
          <div class="category-links">
            <a href={`/peraturan/${electricityRegulation.metadata.slug}/`}>Ketenagalistrikan</a>
            <a href={`/peraturan/${safetyRegulation.metadata.slug}/`}>Keselamatan Ketenagalistrikan</a>
            <a href={`/peraturan/${businessRegulation.metadata.slug}/`}>Usaha Ketenagalistrikan</a>
            <a href={`/peraturan/${environmentRegulation.metadata.slug}/`}>Lingkungan Hidup</a>
            <a href={`/peraturan/${standardizationRegulation.metadata.slug}/`}>Standardisasi</a>
            <a href={`/peraturan/${busbarRegulation.metadata.slug}/`}>SNI Bus Bar Tembaga</a>
            <a href={`/peraturan/${standardizationRegulation.metadata.slug}/`}>Penilaian Kesesuaian</a>
            <a href={`/peraturan/${licensingRegulation.metadata.slug}/`}>Perizinan Berusaha</a>
            <a href="/prototype/reverse-prompt/">QA Pipeline</a>
          </div>
          <p class="compact-note">
            Batch reverse prompt terbaru sudah tampil sebagai konten utama dengan struktur
            pasal, ayat, dan penjelasan yang bisa dicari langsung.
          </p>
        </div>
      </section>
    </main>

    <script id="search-data" type="application/json" is:inline set:html={JSON.stringify(searchRows)}></script>
    <script>
      const dataElement = document.getElementById("search-data");
      type SearchRow = {
        slug: string;
        title: string;
        searchTitle: string;
        documentType: string;
        documentTypeAlias: string;
        number: string;
        year: string;
        id: string;
        kind: string;
        label: string;
        part: string;
        text: string;
      };
      const rows = JSON.parse(dataElement?.textContent || "[]") as SearchRow[];
      const input = document.getElementById("site-search") as HTMLInputElement | null;
      const form = document.getElementById("site-search-form") as HTMLFormElement | null;
      const results = document.getElementById("search-results");
      const summary = document.getElementById("search-summary");

      function normalizeSearchValue(value: string) {
        return value.toLowerCase().replace(/[^a-z0-9]+/g, " ").replace(/\s+/g, " ").trim();
      }

      function documentIdentifiers(item: SearchRow) {
        return [
          `${item.documentType} nomor ${item.number} tahun ${item.year}`,
          `${item.documentTypeAlias} nomor ${item.number} tahun ${item.year}`,
          `${item.documentType} ${item.number} ${item.year}`,
          `${item.documentTypeAlias} ${item.number} ${item.year}`
        ]
          .map(normalizeSearchValue)
          .filter(Boolean);
      }

      function renderRows(items: SearchRow[], message: string) {
        if (!results || !summary) return;
        results.replaceChildren();
        summary.textContent = message;
        results.classList.toggle("is-hidden", items.length === 0);
        for (const item of items.slice(0, 12)) {
          const row = document.createElement("article");
          row.className = "result-row";

          const meta = document.createElement("small");
          meta.textContent = `${item.label} · ${item.part === "explanation" ? "Penjelasan" : "Batang tubuh"}`;

          const link = document.createElement("a");
          link.href = `/peraturan/${item.slug}/#${item.id}`;
          link.textContent = item.title;

          const text = document.createElement("p");
          text.textContent = item.text;

          row.append(meta, link, text);
          results.append(row);
        }
      }

      function runSearch() {
        const query = normalizeSearchValue(String(input?.value || ""));
        if (query.length < 2) {
          renderRows([], "Ketik minimal 2 karakter untuk mencari isi dokumen.");
          return;
        }
        const queryTerms = query.split(" ").filter((term) => term.length > 1);
        const matches = rows
          .map((item, index) => {
            const title = normalizeSearchValue(item.searchTitle || item.title);
            const text = normalizeSearchValue(item.text);
            const docIds = documentIdentifiers(item);
            const docIdInQuery = docIds.some((docId) => query.includes(docId));
            const docIdTerms = new Set(docIds.flatMap((docId) => docId.split(" ")));
            const contentTerms = docIdInQuery
              ? queryTerms.filter((term) => !docIdTerms.has(term) && term !== "nomor" && term !== "tahun")
              : queryTerms;
            const inTitle = title.includes(query);
            const inText = text.includes(query);
            const allTermsInTitle = queryTerms.every((term) => title.includes(term));
            const allTermsInText = queryTerms.every((term) => text.includes(term));
            const docScopedText = docIdInQuery && contentTerms.every((term) => title.includes(term) || text.includes(term));
            const titleRow = item.kind === "title";
            if (!inText && !(titleRow && (inTitle || allTermsInTitle || docIdInQuery)) && !allTermsInText && !docScopedText) return null;
            const score =
              (docIdInQuery && titleRow ? 1500 : 0) +
              (inTitle && titleRow ? 1000 : 0) +
              (allTermsInTitle && titleRow ? 750 : 0) +
              (docScopedText ? 400 : 0) +
              (allTermsInText ? 200 : 0) +
              (text.startsWith(query) ? 100 : 0) +
              (titleRow ? 50 : 0) +
              (item.kind === "chapter" ? 25 : 0);
            return { item, score, index };
          })
          .filter((entry): entry is { item: SearchRow; score: number; index: number } => entry !== null)
          .sort((a, b) => b.score - a.score || a.index - b.index)
          .map((entry) => entry.item);
        renderRows(matches, `${matches.length} hasil ditemukan untuk "${query}".`);
      }

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        runSearch();
      });
      input?.addEventListener("input", runSearch);
      runSearch();
    </script>
  </body>
</html>
