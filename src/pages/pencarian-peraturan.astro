---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import { documentTypeAlias, regulations, regulationSearchRows } from "../lib/regulations";

const title = "Pencarian Peraturan";
const searchRows = regulationSearchRows();
const documentTypes = [...new Set(regulations.map((item) => item.metadata.document_type))].sort();
const popularQueries = [
  "ketenagalistrikan",
  "perizinan berusaha",
  "standardisasi",
  "pengadaan barang",
  "limbah B3",
  "kendaraan listrik",
  "pemberantasan korupsi",
  "SNI bus bar"
];
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Pencarian full-text peraturan energi dan peraturan pendukung yang sudah live." />
    <title>{title} | Website Peraturan Energi</title>
  </head>
  <body>
    <SiteHeader />

    <main class="page-shell public-page">
      <section class="public-hero" aria-labelledby="search-title">
        <p class="eyebrow">Pencarian Peraturan</p>
        <h1 id="search-title">Cari kata kunci sampai ke isi peraturan.</h1>
        <p class="lede">
          Masukkan kata, frasa, nomor, tahun, atau topik hukum untuk menelusuri judul,
          batang tubuh, dan penjelasan peraturan yang sudah tersedia di website ini.
        </p>
      </section>

      <section class="search-workspace" aria-label="Pencarian peraturan">
        <div class="search-main panel">
          <form class="search-form search-form-stacked" id="site-search-form">
            <label for="site-search">Cari peraturan</label>
            <div class="search-action-row">
              <input
                id="site-search"
                type="search"
                autocomplete="off"
                placeholder="Contoh: tarif listrik, PP 28 2025, limbah B3"
              />
              <button type="submit">Cari</button>
            </div>
          </form>
          <div class="quick-query-group" aria-label="Pencarian populer">
            <p class="eyebrow">Pencarian Populer</p>
            <div class="quick-pills">
              {popularQueries.map((query) => <button class="filter-chip" type="button" data-query={query}>{query}</button>)}
            </div>
          </div>
          <div id="search-summary" class="search-summary" aria-live="polite"></div>
          <div id="search-results" class="search-results is-hidden"></div>
        </div>

        <aside class="panel guide-panel" aria-labelledby="search-guide-title">
          <p class="eyebrow">Jelajahi Berdasarkan Jenis</p>
          <div class="quick-pills type-pills">
            {documentTypes.map((type) => <button class="filter-chip" type="button" data-query={documentTypeAlias(type)}>{type}</button>)}
          </div>
          <h2 id="search-guide-title">Tips Pencarian</h2>
          <ul class="plain-list">
            <li>Gunakan kata tunggal untuk topik umum, misalnya <strong>standardisasi</strong>.</li>
            <li>Gunakan frasa untuk konteks yang lebih spesifik, misalnya <strong>perizinan berusaha</strong>.</li>
            <li>Gunakan nomor dan tahun untuk menemukan dokumen tertentu, misalnya <strong>PP 28 2025</strong>.</li>
            <li>Gunakan istilah bidang usaha untuk melihat keterkaitan lintas peraturan.</li>
          </ul>
        </aside>
      </section>
    </main>

    <script id="search-data" type="application/json" is:inline set:html={JSON.stringify(searchRows)}></script>
    <script>
      const dataElement = document.getElementById("search-data");
      type SearchRow = {
        slug: string;
        title: string;
        searchTitle: string;
        documentType: string;
        documentTypeAlias: string;
        number: string;
        year: string;
        id: string;
        kind: string;
        label: string;
        part: string;
        text: string;
      };
      const rows = JSON.parse(dataElement?.textContent || "[]") as SearchRow[];
      const input = document.getElementById("site-search") as HTMLInputElement | null;
      const form = document.getElementById("site-search-form") as HTMLFormElement | null;
      const results = document.getElementById("search-results");
      const summary = document.getElementById("search-summary");
      const queryButtons = Array.from(document.querySelectorAll("[data-query]")) as HTMLButtonElement[];

      type SearchGroup = {
        slug: string;
        title: string;
        documentType: string;
        year: string;
        score: number;
        index: number;
        matches: SearchRow[];
      };

      function normalizeSearchValue(value: string) {
        return value.toLowerCase().replace(/[^a-z0-9]+/g, " ").replace(/\s+/g, " ").trim();
      }

      function documentIdentifiers(item: SearchRow) {
        return [
          `${item.documentType} nomor ${item.number} tahun ${item.year}`,
          `${item.documentTypeAlias} nomor ${item.number} tahun ${item.year}`,
          `${item.documentType} ${item.number} ${item.year}`,
          `${item.documentTypeAlias} ${item.number} ${item.year}`
        ]
          .map(normalizeSearchValue)
          .filter(Boolean);
      }

      function escapeRegExp(value: string) {
        return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      }

      function previewText(text: string, queryTerms: string[]) {
        const compact = text.replace(/\s+/g, " ").trim();
        const lower = compact.toLowerCase();
        const firstIndex = queryTerms
          .map((term) => lower.indexOf(term))
          .filter((index) => index >= 0)
          .sort((a, b) => a - b)[0] ?? 0;
        const start = Math.max(0, firstIndex - 96);
        const end = Math.min(compact.length, firstIndex + 220);
        const prefix = start > 0 ? "... " : "";
        const suffix = end < compact.length ? " ..." : "";
        return `${prefix}${compact.slice(start, end)}${suffix}`;
      }

      function appendHighlightedText(target: HTMLElement, text: string, queryTerms: string[]) {
        const terms = [...new Set(queryTerms)].filter((term) => term.length > 1);
        if (terms.length === 0) {
          target.textContent = text;
          return;
        }
        const pattern = new RegExp(`(${terms.map(escapeRegExp).join("|")})`, "gi");
        let lastIndex = 0;
        for (const match of text.matchAll(pattern)) {
          const index = match.index ?? 0;
          if (index > lastIndex) target.append(document.createTextNode(text.slice(lastIndex, index)));
          const mark = document.createElement("mark");
          mark.textContent = match[0];
          target.append(mark);
          lastIndex = index + match[0].length;
        }
        if (lastIndex < text.length) target.append(document.createTextNode(text.slice(lastIndex)));
      }

      function renderGroups(groups: SearchGroup[], totalMatches: number, queryTerms: string[], rawQuery: string) {
        if (!results || !summary) return;
        results.replaceChildren();
        const cleanQuery = rawQuery.trim();
        summary.textContent = groups.length === 0
          ? `Tidak ada peraturan yang memuat "${cleanQuery}".`
          : `${groups.length} peraturan memiliki kata kunci "${cleanQuery}" dengan ${totalMatches} kecocokan teks.`;
        results.classList.toggle("is-hidden", groups.length === 0);
        for (const group of groups) {
          const row = document.createElement("article");
          row.className = "result-group";

          const header = document.createElement("div");
          header.className = "result-group-header";

          const titleBox = document.createElement("div");
          const meta = document.createElement("small");
          meta.textContent = `${group.documentType} · ${group.year}`;

          const link = document.createElement("a");
          link.href = `/peraturan/${group.slug}/`;
          link.textContent = group.title;

          titleBox.append(meta, link);

          const count = document.createElement("span");
          count.className = "result-count";
          count.textContent = `${group.matches.length} kecocokan`;

          header.append(titleBox, count);
          row.append(header);

          const snippets = document.createElement("div");
          snippets.className = "result-snippets";

          const previewMatches = [...group.matches].sort((a, b) => {
            const aTitle = a.kind === "title" ? 1 : 0;
            const bTitle = b.kind === "title" ? 1 : 0;
            return aTitle - bTitle;
          });
          for (const item of previewMatches.slice(0, 3)) {
            const snippet = document.createElement("a");
            snippet.className = "result-snippet";
            snippet.href = `/peraturan/${item.slug}/#${item.id}`;

            const snippetMeta = document.createElement("small");
            snippetMeta.textContent = `${item.label} · ${item.part === "explanation" ? "Penjelasan" : "Batang tubuh"}`;

            const text = document.createElement("p");
            appendHighlightedText(text, previewText(item.text, queryTerms), queryTerms);

            snippet.append(snippetMeta, text);
            snippets.append(snippet);
          }

          row.append(snippets);
          results.append(row);
        }
      }

      function runSearch() {
        const rawQuery = String(input?.value || "");
        const query = normalizeSearchValue(rawQuery);
        if (query.length < 2) {
          if (results && summary) {
            results.replaceChildren();
            results.classList.add("is-hidden");
            summary.textContent = "Ketik minimal 2 karakter untuk mencari isi dokumen.";
          }
          return;
        }
        const queryTerms = query.split(" ").filter((term) => term.length > 1);
        const matches = rows
          .map((item, index) => {
            const title = normalizeSearchValue(item.searchTitle || item.title);
            const text = normalizeSearchValue(item.text);
            const docIds = documentIdentifiers(item);
            const docIdInQuery = docIds.some((docId) => query.includes(docId));
            const docIdTerms = new Set(docIds.flatMap((docId) => docId.split(" ")));
            const contentTerms = docIdInQuery
              ? queryTerms.filter((term) => !docIdTerms.has(term) && term !== "nomor" && term !== "tahun")
              : queryTerms;
            const inTitle = title.includes(query);
            const inText = text.includes(query);
            const allTermsInTitle = queryTerms.every((term) => title.includes(term));
            const allTermsInText = queryTerms.every((term) => text.includes(term));
            const docScopedText = docIdInQuery && contentTerms.every((term) => title.includes(term) || text.includes(term));
            const titleRow = item.kind === "title";
            if (!inText && !(titleRow && (inTitle || allTermsInTitle || docIdInQuery)) && !allTermsInText && !docScopedText) return null;
            const score =
              (docIdInQuery && titleRow ? 1500 : 0) +
              (inTitle && titleRow ? 1000 : 0) +
              (allTermsInTitle && titleRow ? 750 : 0) +
              (docScopedText ? 400 : 0) +
              (allTermsInText ? 200 : 0) +
              (text.startsWith(query) ? 100 : 0) +
              (titleRow ? 50 : 0) +
              (item.kind === "chapter" ? 25 : 0);
            return { item, score, index };
          })
          .filter((entry): entry is { item: SearchRow; score: number; index: number } => entry !== null)
          .sort((a, b) => b.score - a.score || a.index - b.index)
        const grouped = new Map<string, SearchGroup>();
        for (const match of matches) {
          const current = grouped.get(match.item.slug);
          if (current) {
            current.matches.push(match.item);
            current.score = Math.max(current.score, match.score);
            current.index = Math.min(current.index, match.index);
          } else {
            grouped.set(match.item.slug, {
              slug: match.item.slug,
              title: match.item.title,
              documentType: match.item.documentType,
              year: match.item.year,
              score: match.score,
              index: match.index,
              matches: [match.item]
            });
          }
        }
        const groups = [...grouped.values()].sort((a, b) => b.score - a.score || a.index - b.index);
        renderGroups(groups, matches.length, queryTerms, rawQuery);
      }

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        runSearch();
      });
      input?.addEventListener("input", runSearch);
      for (const button of queryButtons) {
        button.addEventListener("click", () => {
          if (!input) return;
          input.value = String(button.dataset.query || "");
          input.focus();
          runSearch();
        });
      }
      runSearch();
    </script>
  </body>
</html>
